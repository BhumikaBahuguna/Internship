PORT=5000
NODE_ENV=development

# MONGO_URI Notes:
# If your password contains special characters (@, #, $, etc.),
# make sure to URL encode them (e.g., @ becomes %40, # becomes %23).
MONGO_URI=your_mongodb_connection_string_with_encoded_password

CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

FRONTEND_URL=http://localhost:5173

JWT_SECRET=your_strong_jwt_secret_key
JWT_EXPIRES_IN=7d

# Optional SMTP Configuration (if missing, backend will still start but email OTP will fail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_16_digit_gmail_app_password_without_spaces
SMTP_FROM="Project Auth <your_email@gmail.com>"

OTP_EXPIRES_IN_MINUTES=10
